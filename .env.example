# Copy to .env and fill in.
# Env vars override settings.yaml. Keys use double-underscore "__" to navigate
# nested config (e.g. AGENT_RUNTIME__MODEL maps to runtime.model in settings.yaml).

# ---- OpenAI ----
OPENAI_API_KEY=sk-...

# ---- Runtime (pick mock or openai) ----
AGENT_RUNTIME__MODE=openai
AGENT_RUNTIME__MODEL=gpt-4o-mini
AGENT_RUNTIME__TEMPERATURE=0.0
AGENT_RUNTIME__MAX_TOKENS=512
AGENT_RUNTIME__SEED=17

# ---- Embeddings (hash for offline tests, openai for real semantic memory) ----
AGENT_EMBEDDING__MODE=openai
AGENT_EMBEDDING__MODEL=text-embedding-3-small

# ---- Storage ----
REDIS_URL=redis://localhost:6379/0

# ---- Toggles (set to true if you don't want to spin up redis / chroma) ----
AGENT_USE_FAKE_REDIS=true
AGENT_USE_EPHEMERAL_CHROMA=true
